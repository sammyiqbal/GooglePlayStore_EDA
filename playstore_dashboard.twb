      <column caption='Highly Rated Pct' datatype='real' name='[Calculation_2057246164295681]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Rating] &gt;= 4.5 THEN 1 ELSE 0 END) / COUNT([App]) * 100' />
