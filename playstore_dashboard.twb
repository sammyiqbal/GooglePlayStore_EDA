      <column caption='Free Percentage' datatype='real' name='[Calculation_1623212307296257]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF[Type]=&quot;Free&quot; THEN 1 ELSE 0 END)/COUNT([App])*100' />
      </column>
      <column caption='Avg Rating' datatype='real' name='[Calculation_1623212307460098]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Rating])' />
